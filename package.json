{
  "name": "@print-design/vue",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "轻量级、数据驱动的 Vue 3 打印模板设计器库",
  "main": "./dist/print-design.cjs.js",
  "module": "./dist/print-design.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/print-design.es.js",
      "require": "./dist/print-design.cjs.js"
    },
    "./compiler": {
      "types": "./dist/compiler.d.ts",
      "import": "./dist/compiler.es.js",
      "require": "./dist/compiler.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build -c vite.config.lib.ts && vite build -c vite.config.umd.ts",
    "build:app": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "tsx scripts/test-compiler.mjs"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "lodash-es": "^4.17.21",
    "nanoid": "^5.0.7",
    "naive-ui": "^2.38.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.12.10",
    "@vitejs/plugin-vue": "^5.0.4",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vite-plugin-dts": "^4.5.3",
    "vue": "^3.4.21",
    "vue-tsc": "^2.0.13"
  }
}
